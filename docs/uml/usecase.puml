@startuml
left to right direction

actor User

rectangle "Color App Website" {

  usecase "Log In" as UC1
  usecase "Log Out" as UC2
  usecase "Add Color" as UC3
  usecase "Search Colors" as UC4
  usecase "View Search Results" as UC5
}

' --- User interactions ---
User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5

' --- Includes (logic relationships) ---
UC3 ..> UC1 : <<include>>
UC4 ..> UC1 : <<include>>
UC4 ..> UC5 : <<include>>

@enduml